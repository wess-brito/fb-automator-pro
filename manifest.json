{
  "manifest_version": 3,
  "name": "FB Automator Pro",
  "version": "1.0.2",
  "description": "Convida automaticamente quem reagiu aos posts para curtir sua página no Facebook.",
  "permissions": [
    "scripting",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.facebook.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}